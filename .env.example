# Copy this file to .env and fill in real values before starting.
# NEVER commit .env to version control.

# ── Required ──────────────────────────────────────────────────────────────────

# Random secret used to sign JWT tokens  (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING

# Initial admin password (you can change it after first login via the Admin UI)
ADMIN_PASSWORD=changeme123

# Allowed CORS origin for the frontend (set to your domain in production)
FRONTEND_ORIGIN=http://localhost

# ── JAR paths — local / Docker Compose deployment ─────────────────────────────
# Use these when you have the LSEG JARs on disk (local or VPS).

# Production JAR  (env = prod, qa, trd, dev)
MSG_FEED_JAR_PROD=/path/to/message-feed-0.0.42.0.jar

# PPE / Beta JAR  (env = beta)
MSG_FEED_JAR_PPE=/path/to/message-feed-ppe-0.0.41.0.jar

# Plugins directory (shared by both JARs)
PLUGIN_DIR=/path/to/plugins

# ── JAR download URLs — Render / cloud deployment ─────────────────────────────
# Use these when deploying to Render or any Docker-based cloud host that cannot
# mount local volumes.  start.sh will download the JARs at container startup.
# Host your JARs at a privately accessible HTTPS URL:
#   • AWS S3 pre-signed URL
#   • Google Cloud Storage signed URL
#   • Azure Blob SAS URL
#   • Direct HTTPS link (Dropbox: change ?dl=0 to ?dl=1)

# MSG_FEED_JAR_URL_PROD=https://example.com/message-feed-0.0.42.0.jar
# MSG_FEED_JAR_URL_PPE=https://example.com/message-feed-ppe-0.0.41.0.jar

# ── Optional overrides ────────────────────────────────────────────────────────
# JAVA_BIN=java
# MAX_MESSAGES=500

# Custom truststore — only needed if Java's default cacerts cause SSL errors.
# On standard cloud servers (Render, AWS, etc.) you typically do NOT need this.
# TRUST_STORE=/path/to/lseg-truststore.jks
# TRUST_STORE_PASS=changeit
# TRUST_STORE_URL=https://example.com/lseg-truststore.jks
